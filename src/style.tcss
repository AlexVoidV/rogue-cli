Screen {
    layout: vertical;
}

GameScreen {
    width: 100%;
    height: 1fr;
    background: black;
    color: green;
    text-style: bold;
}

#stats_panel {
    /* width: 100%; */
    height: 6;
    background: $surface-darken-2;
    padding: 0 1;
    /* border-top: solid $accent; */
}

#bars_row {
    height: 3;
    width: 100%;
}

ProgressBar {
    width: 50%;
}

#hp_bar,
#xp_bar {
    height: 1;
    width: 1fr;
    margin: 0 !important;
    padding: 0 !important;
}

#hp_bar {
    margin-right: 0;
}

#xp_bar {
    margin-left: 0;
}

#stats_text_container {
    height: 1;
    margin-top: 1;
}

#stats_text {
    width: 100%;
}

#hp_bar .bar--complete {
    background: red;
}

#xp_bar .bar--complete {
    background: yellow;
    color: black;
}

Header,
Footer {
    height: 3;
}